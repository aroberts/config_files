# Equivalent of macOS Terminal.app "Pro" profile

# theme = qorbani
# theme = Zenwritten Dark
theme = Sublette
# theme = Apple System Colors
# window-theme = system

# Font
font-family = Monaco for Powerline
font-size = 15
adjust-cell-height = +22%


# Window
window-width = 130
window-height = 44
working-directory = home
window-inherit-working-directory = false
window-padding-x = 8
window-padding-y = 0,5

# Behavior
# confirm-close-surface = false
shell-integration = zsh
# ssh-terminfo intentionally omitted: its wrapper closes the SSH session when
# tmux detaches. Install xterm-ghostty terminfo per-host with the
# `install-ghostty-ssh-terminfo` shell function (see aliases).
shell-integration-features = cursor,title,path
# note: see zshrc "ghostty integration"

# scrollback-limit in bytes, roughly 125,000 lines
scrollback-limit = 100000000

